# Copy to .env. Same user/host/port for both; DATABASE and CLASSIFIED8_DATABASE are the two database names.

DB_USER=user
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=3306
DATABASE=users_metadata
CLASSIFIED8_DATABASE=classified8
USERS_DB_TABLE_NAME=clas_users

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_PREFETCH=10

# Processing
WORKERS=5
RULE_CACHE_TTL=1m
SHUTDOWN_TIMEOUT=30s
