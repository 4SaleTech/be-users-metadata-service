# Template for .env. Copy to .env for local runs.
# Behaviour: .env is used as fallback; OS environment variables take precedence (never overwritten).

# Database: DATABASE = metadata service DB (event_sources, processed_events, etc.). CLASSIFIED8_DATABASE = DB with clas_users (same host/user).
# DATABASE_URL=user:password@tcp(localhost:3306)/be_users_metadata_service?charset=utf8mb4&parseTime=True
DB_USER=user
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=3306
DATABASE=be_users_metadata_service
CLASSIFIED8_DATABASE=classified8
DB_CHARSET=utf8mb4
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# RabbitMQ: full AMQP URL (takes precedence) or separate vars. Stream uses same user/password, port 5552.
# Staging example (use RABBITMQ_URL or set host/port/user/password):
# RABBITMQ_URL=amqp://4sale-rabbitmq-admin:PASSWORD@rabbitmq-stg.rabbitmq-system.svc.cluster.local:5672/%2f
# RABBITMQ_HOST=rabbitmq-stg-nlb-24d4c1440fa2a16a.elb.eu-west-1.amazonaws.com
# RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_PREFETCH=10

# Super stream (port 5552). When enabled, stream names from event_sources.topic_name; uses RABBITMQ_HOST.
# RABBITMQ_STREAM_ENABLED=false
# RABBITMQ_STREAM_PORT=5552
# Processing
WORKERS=5
RULE_CACHE_TTL=1m
SHUTDOWN_TIMEOUT=30s
