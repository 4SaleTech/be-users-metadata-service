# Copy to .env and set values. OS environment variables override these.

# Database: full DSN or separate vars. DB_USERNAME/DB_DATABASE accepted (e.g. Laravel-style env).
# DATABASE_URL=user:password@tcp(localhost:3306)/users_metadata?charset=utf8mb4&parseTime=True
# Staging example:
# DB_USERNAME=4saledevpower
# DB_PASSWORD=YOUR_PASSWORD
# DB_HOST=staging-jan-4-2023-cluster.cluster-cylpew54lkmg.eu-west-1.rds.amazonaws.com
# DB_PORT=3306
# DB_DATABASE=classified8
DB_USER=user
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=3306
DB_NAME=users_metadata
DB_CHARSET=utf8mb4
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# RabbitMQ: full AMQP URL (takes precedence) or separate vars. Stream uses same user/password, port 5552.
# Staging example (use RABBITMQ_URL or set host/port/user/password):
# RABBITMQ_URL=amqp://4sale-rabbitmq-admin:PASSWORD@rabbitmq-stg.rabbitmq-system.svc.cluster.local:5672/%2f
# RABBITMQ_HOST=rabbitmq-stg-nlb-24d4c1440fa2a16a.elb.eu-west-1.amazonaws.com
# RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_PREFETCH=10

# Super Stream (stream protocol, port 5552). Set RABBITMQ_STREAM_ENABLED=true to consume from a super stream.
# RABBITMQ_STREAM_ENABLED=false
# RABBITMQ_SUPER_STREAM_NAME=user_events
# RABBITMQ_STREAM_HOST=localhost
# RABBITMQ_STREAM_PORT=5552

# Processing
WORKERS=5
RULE_CACHE_TTL=1m
SHUTDOWN_TIMEOUT=30s
