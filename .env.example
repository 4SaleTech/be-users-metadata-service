# Template for .env. Copy to .env for local runs.
# .env is fallback; OS environment variables take precedence.

# Two database URLs (MySQL DSN):
# DATABASE_URL = this service's database (event_sources, metadata_rules, processed_events, failed_events)
# DATABASE_USERS_URL = classified8 database (clas_users table for meta_data)
DATABASE_URL=user:password@tcp(localhost:3306)/users_metadata?charset=utf8mb4&parseTime=True
DATABASE_USERS_URL=user:password@tcp(localhost:3306)/classified8?charset=utf8mb4&parseTime=True
USERS_DB_TABLE_NAME=clas_users

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_VHOST=/
RABBITMQ_PREFETCH=10

# Super Stream (optional)
# RABBITMQ_STREAM_ENABLED=false
# RABBITMQ_SUPER_STREAM_NAME=user_events
# RABBITMQ_STREAM_HOST=localhost
# RABBITMQ_STREAM_PORT=5552

# Processing
WORKERS=5
RULE_CACHE_TTL=1m
SHUTDOWN_TIMEOUT=30s
